# Copy to .env and replace every value.

# --- MinIO / AIStor ROOT (bootstrap + admin only; NEVER used by engines) ---
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change-me-strong-root-pw

# --- Scoped lakehouse identity (this is what the engines use) ---
# In MinIO, a user's name IS its S3 access key, and its password IS the secret key.
# These must match the s3.aws-access-key / s3.aws-secret-key in trino/catalog/lakehouse.properties.
LAKE_USER=lakehouse
LAKE_PASSWORD=change-me-strong-lake-pw

# --- Nessie catalog metadata database (Postgres) ---
NESSIE_DB_NAME=nessie
NESSIE_DB_USER=nessie
NESSIE_DB_PASSWORD=change-me-strong-nessie-pw

# --- Trino JVM heap ---
TRINO_HEAP=2G
